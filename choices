<p>Will You be attending Lunch today? </p>
<button onclick="showMsg('Lunch: Yes')">Yes</button>
<button onclick="showMsg('Lunch: No')">No, I'll Skip</button>

<p>Will You be attending Dinner today? </p>
<button onclick="showMsg('Dinner: Yes')">Yes</button>
<button onclick="showMsg('Dinner: No')">No, I'll Skip</button>

<h3 id="message"></h3>

<script>
function showMsg(text) {
    document.getElementById("message").innerHTML = text + " selected!";
}
</script>

