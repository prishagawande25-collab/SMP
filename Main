#include <iostream>
using namespace std;

int main() {
int pin = 1234, enteredPin;
double balance = 1000, amount;
int choice;

cout << "Enter PIN: ";
cin >> enteredPin;

if (enteredPin != pin) {
cout << "Wrong PIN!";
return 0;
}

do {
cout << "\n1.Check Balance\n2.Deposit\n3.Withdraw\n4.Exit\n";
cin >> choice;

if (choice == 1) {
cout << "Balance: " << balance << endl;
}
else if (choice == 2) {
cout << "Enter amount: ";
cin >> amount;
balance += amount;
}
else if (choice == 3) {
cout << "Enter amount: ";
cin >> amount;
if (amount > balance)
cout << "Not enough balance\n";
else
balance -= amount;
}
}
while (choice != 4);

 return 0;
}
